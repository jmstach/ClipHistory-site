# R2 (Cloudflare) credentials for the /api/subscribe endpoint.
# Copy to .env.local for `vercel dev`, and set the same keys in
# Vercel Project Settings → Environment Variables for production.
#
# Reuse the Markset R2 account/credentials if you like — the list is kept
# in a separate object key (cliphistory-emails.json), so the bucket can be
# shared. R2_BUCKET_NAME just needs to point at a bucket those keys can write.

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
