#!/usr/bin/env bash
# Smarten straight quotes in staged HTML files before commit.
set -e

repo_root=$(git rev-parse --show-toplevel)
mapfile -t files < <(git diff --cached --name-only --diff-filter=ACMR -- '*.html')

if [ ${#files[@]} -eq 0 ]; then
  exit 0
fi

node "$repo_root/scripts/smarten-quotes.js" "${files[@]}"
git add -- "${files[@]}"
